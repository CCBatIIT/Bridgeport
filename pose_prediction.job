#!/bin/sh
#SBATCH --job-name="PoseJob"
#SBATCH --output="./logs/PoseJob.%j.%N.out"
#SBATCH --partition=gpu-shared
#SBATCH --gpus=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --mem=48G
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=dcooper6@hawk.iit.edu
#SBATCH --account=iit119
#SBATCH --no-requeue
#SBATCH -t 10:00:00


source ~/.bashrc

conda activate yank_env

cd $SLURM_SUBMIT_DIR

echo $1 POSE PREDICTION, centroid $2 run $3, type $4
python ./pose_prediction.py $1 $2 $3 $4 $5


